# Server
PORT=3399
DATABASE_URL=postgres://pagesai:pagesai@localhost:5433/pagesai
REDIS_URL=redis://localhost:6380

# Standalone dev auth (optional). When set, API requires Authorization: Bearer <token>
PAGESAI_DEV_TOKEN=

# hofOS sidecar verification (minted JWT from data-app proxy)
HOF_SUBAPP_JWT_SECRET=

# CLI / web
PAGESAI_API_URL=http://localhost:3399
VITE_PAGESAI_API_URL=http://localhost:3399

# MinIO / S3 (optional — enables POST /api/spaces/:id/upload and GET /api/assets)
# Example matches infra/docker/docker-compose.yml MinIO service (API port 9002).
PAGESAI_S3_ENDPOINT=http://localhost:9002
PAGESAI_S3_BUCKET=pagesai
PAGESAI_S3_ACCESS_KEY=pagesai
PAGESAI_S3_SECRET_KEY=pagesai-pagesai
PAGESAI_S3_REGION=us-east-1
