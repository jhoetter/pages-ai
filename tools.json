{
  "$schema": "https://hofos.dev/schemas/tools-v1.json",
  "subapp": "pagesai",
  "contract_version": "1.0.0",
  "cli_verbs": [
    {
      "name": "status",
      "command": "pages-agent status",
      "summary": "Return PagesAI status.",
      "args": []
    },
    {
      "name": "page list",
      "command": "pages-agent page list",
      "summary": "List pages.",
      "args": []
    },
    {
      "name": "page read",
      "command": "pages-agent page read",
      "summary": "Read a page by id.",
      "args": [{ "name": "id", "type": "string", "required": true }]
    },
    {
      "name": "page create",
      "command": "pages-agent page create",
      "summary": "Create a page.",
      "args": [
        { "name": "title", "type": "string", "required": true },
        { "name": "parent", "type": "string", "required": false }
      ]
    },
    {
      "name": "page update",
      "command": "pages-agent page update",
      "summary": "Update page content.",
      "args": [
        { "name": "id", "type": "string", "required": true },
        { "name": "content", "type": "string", "required": true }
      ]
    },
    {
      "name": "block insert",
      "command": "pages-agent block insert",
      "summary": "Insert a block into a page.",
      "args": [
        { "name": "page", "type": "string", "required": true },
        { "name": "after", "type": "string", "required": false },
        { "name": "content", "type": "string", "required": true }
      ]
    },
    {
      "name": "database create",
      "command": "pages-agent database create",
      "summary": "Create a database in a space.",
      "args": [
        { "name": "space", "type": "string", "required": true },
        { "name": "title", "type": "string", "required": true }
      ]
    },
    {
      "name": "database property add",
      "command": "pages-agent database property add",
      "summary": "Add a property to a database schema.",
      "args": [
        { "name": "database", "type": "string", "required": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "type", "type": "string", "required": true }
      ]
    },
    {
      "name": "database row create",
      "command": "pages-agent database row create",
      "summary": "Create a row (cells JSON object).",
      "args": [
        { "name": "database", "type": "string", "required": true },
        { "name": "cells", "type": "string", "required": true }
      ]
    },
    {
      "name": "database view create",
      "command": "pages-agent database view create",
      "summary": "Create a view (table|board|list|calendar).",
      "args": [
        { "name": "database", "type": "string", "required": true },
        { "name": "name", "type": "string", "required": true },
        { "name": "type", "type": "string", "required": true }
      ]
    },
    {
      "name": "database query",
      "command": "pages-agent database query",
      "summary": "Run a view query.",
      "args": [
        { "name": "database", "type": "string", "required": true },
        { "name": "view", "type": "string", "required": true }
      ]
    }
  ],
  "function_wrappers": [],
  "subagent": null
}
