{
  "name": "@pagesai/hofos-ui",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "dist/*.css"
  ],
  "scripts": {
    "build": "vite build && cp src/index.d.ts dist/index.d.ts",
    "build:dist": "pnpm run build",
    "typecheck": "echo \"types are generated from src/index.d.ts\"",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/react": "^0.43.0",
    "@lexical/rich-text": "^0.43.0",
    "@tanstack/react-query": "^5.62.0",
    "cmdk": "^1.1.1",
    "i18next": "^26.0.4",
    "lexical": "^0.43.0",
    "react-i18next": "^17.0.2",
    "react-router": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "@pagesai/core": "workspace:*",
    "@pagesai/documents": "workspace:*"
  },
  "license": "MIT"
}
