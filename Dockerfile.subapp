# Structural WP-4 subapp Dockerfile stub for PagesAI.
# Replace this with the product's production image build once the full
# standalone-subdomain conversion is implemented.
FROM node:20-bookworm-slim
WORKDIR /app
COPY hof-module.json tools.json ./
COPY cli/pages-agent /usr/local/bin/pages-agent
RUN chmod +x /usr/local/bin/pages-agent
ENV HOF_SUBAPP_NAME=pagesai HOF_SUBAPP_AUTH_MODE=inherit
EXPOSE 3399
CMD ["sh", "-c", "while true; do sleep 3600; done"]
